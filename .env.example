# Twitch Configuration
# TWITCH_CLIENT_ID is optional — defaults to the public Phonema app.
# Set only if you fork with your own Twitch app:
# TWITCH_CLIENT_ID=your_client_id_here

# Broadcaster ID & bot username are no longer needed — resolved automatically
# from the OAuth token after browser authorization (Device Code Flow).
# The first time you run phonema, open https://www.twitch.tv/activate and
# enter the displayed code. Your channel info is fetched automatically.

# Logging
LOG_LEVEL=INFO
